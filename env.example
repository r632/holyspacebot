# ============================================================
#  Configuration du Space Launch Bot
# ============================================================

# Token de ton bot Discord
DISCORD_TOKEN=TON_TOKEN_ICI

# ID du canal où les lancements seront annoncés
CHANNEL_ID=TON_CHANNEL_ID_ICI

# Intervalle de vérification en heures (défaut : 6)
CHECK_INTERVAL_HOURS=6

# Chemin de la base SQLite
# Sur Railway avec volume monté sur /data → utilise /data/launches.db
# Sinon laisse vide, le bot détecte automatiquement
# DB_PATH=/data/launches.db
